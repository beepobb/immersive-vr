; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Immersive VR"
run/main_scene="uid://ctltchlf2j2r4"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

XRToolsUserSettings="*res://addons/godot-xr-tools/user_settings/user_settings.gd"
XRToolsRumbleManager="*res://addons/godot-xr-tools/rumble/rumble_manager.gd"
AvatarState="*res://Scripts/ui/avatar_customisation/avatar_state.gd"
XrSimulator="*res://addons/xr-simulator/XRSimulator.tscn"
EnvironmentState="*res://scripts/ui/select_environment/environment_state.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-xr-tools/plugin.cfg")

[gui]

theme/custom="uid://14kqmrsu81bn"

[xr]

openxr/enabled=true
shaders/enabled=true
openxr/size/viewport_height=648
openxr/size/viewport_width=1152
